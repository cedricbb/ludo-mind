{
  "name": "ludo-mind",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "npx jest --no-coverage"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.99.2",
    "expo": "~53.0.0",
    "expo-blur": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~14.0.0",
    "fast-xml-parser": "^5.7.1",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.4.0",
    "supabase": "^2.92.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^11.5.4",
    "@types/react": "^19.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "react-test-renderer": "19.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@supabase/.*)"
    ],
    "moduleNameMapper": {
      "^expo-router$": "<rootDir>/__mocks__/expo-router.ts",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.ts",
      "^expo-blur$": "<rootDir>/__mocks__/expo-blur.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/async-storage.ts"
    }
  }
}
